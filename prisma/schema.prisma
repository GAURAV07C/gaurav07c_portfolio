generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  password String
}

model SiteSettings {
  id                String  @id @default("global")
  heroWords         String
  heroDesc          String
  aboutMe           String
  socialLinks       String
  introductionWords String  @default("[]")
  introductionText  String  @default("")
  profileImage      String?
  resume            String?
}

model Project {
  id          String   @id @default(cuid())
  company     String
  year        String
  title       String
  slug        String   @unique
  results     String   @default("[]")
  techStack   String   @default("[]")
  liveLink    String?
  sourceLink  String?
  demoLink    String?
  image       String
  createdAt   DateTime @default(now())
  isRecent    Boolean  @default(false)
  challenges  String   @default("[]")
  description String   @default("")
  features    String   @default("[]")
  outcomes    String   @default("[]")
  tags        String   @default("[]")
  views       Int      @default(0)
  skills      Skill[]  @relation("ProjectToSkill")
  comments    Comment[]
}

model Blog {
  id        String   @id @default(cuid())
  title     String
  slug      String   @unique
  date      String
  excerpt   String
  content   String
  link      String
  image     String
  createdAt DateTime @default(now())
  tags      String   @default("[]")
  views     Int      @default(0)
  comments  Comment[]
}

model Organisation {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  image       String?
  description String?
  repos       Repository[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Repository {
  id             String        @id @default(cuid())
  organisationId String?
  organisation   Organisation? @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  url            String
  image          String?
  description    String?
  contributions  OpenSource[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([organisationId, slug])
}

model OpenSource {
  id            String   @id @default(cuid())
  repoId        String?
  repo          Repository? @relation(fields: [repoId], references: [id], onDelete: SetNull)
  title         String
  slug          String   @unique
  organisation  String?
  description   String
  repoUrl       String?
  prUrl         String?
  type          String   @default("feature") // bug-fix | feature | documentation | enhancement
  techStack     String   @default("[]")
  date          String
  status        String   @default("merged") // merged | pending | closed
  image         String?
  createdAt     DateTime @default(now())
  views         Int      @default(0)
  comments      Comment[]
}

model Skill {
  id        String    @id @default(cuid())
  title     String    @unique
  iconsType String
  projects  Project[] @relation("ProjectToSkill")
}

model TapeWord {
  id        String   @id @default(cuid())
  word      String
  createdAt DateTime @default(now())
}

model HeroOrbit {
  id           String   @id @default(cuid())
  size         Int
  rotation     Int
  spinDuration String
  starType     String
  starDuration String
  className    String
  createdAt    DateTime @default(now())
}

model Hobby {
  id        String   @id @default(cuid())
  title     String
  emoji     String
  left      String
  top       String
  createdAt DateTime @default(now())
}

model Tool {
  id        String   @id @default(cuid())
  title     String
  iconName  String
  createdAt DateTime @default(now())
}

model Education {
  id        String   @id @default(cuid())
  school    String
  href      String
  degree    String
  logoUrl   String
  start     String
  end       String
  createdAt DateTime @default(now())
}

model Experience {
  id          String   @id @default(cuid())
  company     String
  href        String
  badges      String
  location    String
  title       String
  logoUrl     String
  start       String
  end         String
  description String
  createdAt   DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  position  String
  text      String
  avatar    String
  createdAt DateTime @default(now())
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  name      String
  email     String
  parentId  String?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  blogId    String?
  blog      Blog?    @relation(fields: [blogId], references: [id])
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
  docPageId String?
  docPage   DocPage?  @relation(fields: [docPageId], references: [id])
  openSourceId String?
  openSource   OpenSource? @relation(fields: [openSourceId], references: [id])
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model DocTopic {
  id        String    @id @default(cuid())
  title     String
  slug      String    @unique
  description String?
  icon      String?
  order     Int       @default(0)
  pages     DocPage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DocPage {
  id        String    @id @default(cuid())
  topicId   String
  topic     DocTopic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  title     String
  slug      String
  content   String    @default("")
  order     Int       @default(0)
  views     Int       @default(0)
  comments  Comment[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([topicId, slug])
  @@unique([topicId, order])
}
